---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MemberPopup from '../../components/MemberPopup.astro';
import Pagination from '../../components/Pagination.astro';
import ScrollToMatch from '../../components/ScrollToMatch.astro';
import { getThread, getAllThreadIds, getMember, getForumForThread, type Breadcrumb, type MemberData } from '../../lib/data.ts';
import { SITE_NAME } from 'astro:env/server';
import { formatDateTime, threadSlug, memberSlug, routePath } from '../../lib/format.ts';
import { sanitizeHtml } from '../../lib/sanitize.ts';
import { avatar } from '../../lib/avatar.ts';

const PER_PAGE = 30;

export async function getStaticPaths() {
	const ids = await getAllThreadIds();
	const paths = [];
	for (const id of ids) {
		const thread = await getThread(id);
		if (!thread) continue;
		const s = threadSlug(id, thread.title);
		const totalPages = Math.max(1, Math.ceil(thread.posts.length / 30));
		for (let i = 0; i < totalPages; i++) {
			paths.push({
				params: { slug: i === 0 ? s : `${s}/page/${i + 1}` },
				props: { threadId: id, page: i + 1, totalPages, threadSlug: s },
			});
		}
	}
	return paths;
}

const { threadId, page, totalPages, threadSlug: tSlug } = Astro.props;
const thread = await getThread(threadId);
if (!thread) return Astro.redirect(routePath('/'));
const parentForum = await getForumForThread(threadId);

const crumbs: Breadcrumb[] = [
	{ label: SITE_NAME, href: routePath('/') },
];
if (parentForum) {
	crumbs.push({ label: parentForum.name, href: routePath(`/forum/${parentForum.channelId}`) });
}
crumbs.push({ label: thread.title, href: routePath(`/thread/${tSlug}`) });

const posts = thread.posts.slice((page - 1) * PER_PAGE, page * PER_PAGE);

const authorIds = [...new Set(posts.map((p) => p.authorId))];
const members = new Map<number, MemberData>();
await Promise.all(authorIds.map(async (id) => {
	const m = await getMember(id);
	if (m) members.set(id, m);
}));
---

<Layout title={`${thread.title} — ${SITE_NAME}`}>
	<Breadcrumbs items={crumbs} />

	<h1 class="text-2xl font-bold mb-1 mt-4">{thread.title}</h1>
	<p class="text-(--color-text-muted) mb-6">{thread.posts.length} posts</p>

	<div class="flex flex-col gap-4">
		{posts.map((post) => (
				<article id={`post-${post.id}`} class="rounded-lg bg-(--color-surface-alt) p-4">
					<header class="mb-3 flex flex-wrap items-center gap-3 border-b border-(--color-border) pb-2">
						<a
							href={routePath(`/member/${memberSlug(post.authorId, post.author)}`)}
							class="member-trigger flex items-center gap-2 font-semibold text-inherit no-underline hover:underline"
							data-member-id={post.authorId}
						>
							<span class="inline-block size-6 rounded-full overflow-hidden ring-1 ring-(--color-border)" aria-hidden="true" set:html={avatar(post.author)} />
							{post.author}
						</a>
						<time datetime={post.created} title={post.created} class="text-xs text-(--color-text-muted)">{formatDateTime(post.created)}</time>
							<a href={`#post-${post.id}`} class="ml-auto text-xs text-(--color-text-muted) hover:text-(--color-link) no-underline" aria-label={`Link to post ${post.id}`}>#</a>
						{post.updated && (
							<span class="text-xs italic text-(--color-text-muted)">edited <time datetime={post.updated} title={post.updated}>{formatDateTime(post.updated)}</time></span>
						)}
					</header>

					{post.title && <h2 class="mb-2 text-base font-semibold">{post.title}</h2>}

					<div class="post-body text-sm leading-relaxed break-words" set:html={sanitizeHtml(post.body)} />

					{post.attachments.length > 0 && (
						<footer class="post-footer">
							<h3 class="mb-1 text-xs font-semibold text-(--color-text-muted)">Attachments</h3>
							<ul class="space-y-0.5">
								{post.attachments.map((att) => (
									<li class="text-xs">
										<a href={att.url?.startsWith('/') ? routePath(att.url) : att.url ?? routePath(`/attachments/${att.id}`)} {...((att.url ?? '/').startsWith('/') ? { download: att.name } : { target: '_blank', rel: 'noopener' })} class="text-(--color-link) hover:underline">{att.name}</a>
										{(att.size || att.views > 0) && (
											<span class="text-(--color-text-muted) ml-1">({[att.size, att.views > 0 && `${att.views.toLocaleString()} views`].filter(Boolean).join(', ')})</span>
										)}
									</li>
								))}
							</ul>
						</footer>
					)}
				</article>
		))}
	</div>

	<Pagination currentPage={page} totalPages={totalPages} baseUrl={routePath(`/thread/${tSlug}`)} />

	<MemberPopup members={members} />
</Layout>

<style>
	.post-body :global(blockquote) {
		border-left: 3px solid var(--color-border);
		padding: 0.5rem 0.75rem;
		margin: 0.5rem 0;
		color: var(--color-text-muted);
		background: var(--color-code-bg);
		border-radius: 0 0.25rem 0.25rem 0;
	}

	.post-body :global(pre) {
		background: var(--color-code-bg);
		padding: 0.75rem;
		border-radius: 0.25rem;
		overflow-x: auto;
		font-size: 0.8rem;
		margin: 0.5rem 0;
	}

	.post-body :global(a) {
		color: var(--color-link);
		text-decoration: underline;
	}

	.post-body :global(img) {
		max-width: 100%;
		height: auto;
	}

	.post-footer {
		margin-top: 0.75rem;
		border-top: 1px solid var(--color-border);
		padding-top: 0.5rem;
		background: var(--color-code-bg);
		margin-inline: -1rem;
		margin-bottom: -1rem;
		padding: 0.75rem 1rem;
		border-radius: 0 0 0.5rem 0.5rem;
	}
</style>

<ScrollToMatch selector='article[id^="post-"]' />
